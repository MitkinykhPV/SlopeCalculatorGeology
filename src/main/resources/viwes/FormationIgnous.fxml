                <Polygon fx:id="intrusiveDescription" fill="#ffffff" layoutX="-186.0" layoutY="-26.0" points="203.61, 503.61, 503.61, 503.61, 503.61, 603.61, 203.61, 603.61" stroke="black" strokeWidth="1.1" styleClass="rock-polygon, metamorphic-rock" />

            <Label layoutX="32.0" layoutY="-14.0" prefHeight="78.0" prefWidth="263.0" text="Вулканогенно-осадочные: туффиты, туфопесчаники, туфоалевролиты,  туфоаргилиты" wrapText="true" />
                <Label layoutX="34.0" layoutY="82.0" prefHeight="49.0" prefWidth="251.0" text="Туфы" />
                <Label layoutX="27.0" layoutY="192.0" prefHeight="72.0" prefWidth="265.0" text="Лавобрекчии" />
            <Label layoutX="27.0" layoutY="284.0" prefHeight="77.0" prefWidth="273.0" text="Лавы" />
            <Label layoutX="29.0" layoutY="381.0" prefHeight="85.0" prefWidth="275.0" text="Субвулканические" />
            <Label layoutX="27.0" layoutY="488.0" prefHeight="82.0" prefWidth="280.0" text="Интрузивные" />


            </children>
        </Group>
        <Button fx:id="exitButton" layoutX="453.0" layoutY="694.0" mnemonicParsing="false" onAction="#exitApplication" prefHeight="50.0" prefWidth="100.0" text="Выход" />
        <Button fx:id="backButton" layoutX="43.0" layoutY="694.0" mnemonicParsing="false" onAction="#goBack" prefHeight="50.0" prefWidth="100.0" text="Назад" />
    </children>
</AnchorPane>
