                <Polygon fx:id="subvolcanicDescription" fill="#ffffff" layoutX="-186.0" layoutY="-26.0" points="203.61, 403.61, 503.61, 403.61, 503.61, 503.61, 203.61, 503.61" stroke="black" strokeWidth="1.1" styleClass="rock-polygon, metamorphic-rock" />
