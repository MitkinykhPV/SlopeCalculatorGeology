<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<!--//DC4A1027-HDR Вся группа, если нужно будет увеличить в два раза "scaleGroup" scaleX="2.0" scaleY="2.0" -->
<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.DungeonCommanderController">
    <children>
        <Label text="Выберите тип расчета">
            <font>
                <Font name="Arial Bold" size="24.0" />
            </font>
        </Label>

        <Button fx:id="thicknessCalculationBtn" mnemonicParsing="false" onAction="#openThicknessCalculation" prefHeight="50.0" prefWidth="440.0" text="Расчет толщины предохранительной подушки">
            <font>
                <Font size="16.0" />
            </font>
         <effect>
            <DropShadow />
         </effect>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
        </Button>

        <Button fx:id="otherCalculationBtn" mnemonicParsing="false" onAction="#openOtherCalculation" prefHeight="50.0" prefWidth="440.0" text="Расчет высоты обрушения">
            <font>
                <Font size="16.0" />
            </font>
         <effect>
            <DropShadow />
         </effect>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
        </Button>
      <Button fx:id="otherGeology" mnemonicParsing="false" onAction="#openOtherGyology" prefHeight="50.0" prefWidth="440.0" text="Геологическая справка">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
         <effect>
            <DropShadow />
         </effect>
         <font>
            <Font size="16.0" />
         </font>
      </Button>

        <Button fx:id="exitButton" mnemonicParsing="false" onAction="#exitApplication" prefHeight="50.0" prefWidth="350.0" text="Выход">
            <font>
                <Font size="16.0" />
            </font>
         <effect>
            <DropShadow />
         </effect>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
        </Button>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <effect>
      <Blend />
   </effect>
</VBox>
